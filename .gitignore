# # .NET specific ignores:

## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates
*.playlist

# https://github.com/VerifyTests/Verify
*.received.*

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
**/[Bb]in/
**/[Bb]in/**
**/[Bb]in\\*/
[Oo]bj/
**/[Oo]bj/**
[Ll]og/
.nuke/temp/

# Defensive ignores for odd character-prefixed build folders on WSL/mounted filesystems
**/*[Bb]in/
**/*[Bb]in/**
**/*[Oo]bj/
**/*[Oo]bj/**
**/[Bb]in*/
**/[Bb]in*/**
**/[Dd]ebug*/
**/[Dd]ebug*/**

# vscode
.vscode/

# Visual Studio workspace settings
/.vs/

# Application logs
logs/
artifacts/

# Test output
TestResults/

# Claude
.claude/settings.local.json
